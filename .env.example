# Development Mode (set to true to bypass Supabase Auth for testing)
NEXT_PUBLIC_DEV_MODE=true

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Cloudflare Turnstile (Human Verification)
# Get keys at https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAA...
TURNSTILE_SECRET_KEY=0x4AAAAAA...

# Attendance Configuration
NEXT_PUBLIC_ATTENDANCE_CUTOFF_HOUR=8
NEXT_PUBLIC_ATTENDANCE_CUTOFF_MINUTE=0

# WhatsApp Cloud API (for staff task notifications)
# 1. Create a Meta Business Account at https://business.facebook.com
# 2. Register a business phone number at https://business.whatsapp.com
# 3. Generate a permanent access token
# 4. Find your Phone Number ID in WhatsApp Manager
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# WhatsApp Webhook verification token (used by Meta to verify your webhook endpoint)
# Set this to any secret string, then enter the same value in Meta's webhook config.
# The webhook endpoint is: https://your-domain.com/api/whatsapp/webhook
WHATSAPP_VERIFY_TOKEN=afcs_webhook_2026

# WhatsApp Message Templates (required by Meta for proactive outbound messages)
# Create templates at https://business.facebook.com > WhatsApp Manager > Message Templates
# After approval, set the template names here:
WHATSAPP_TEMPLATE_DUTY=duty_assignment
WHATSAPP_TEMPLATE_TASK=task_assignment
WHATSAPP_TEMPLATE_PERIOD=period_reminder
WHATSAPP_TEMPLATE_BROADCAST=broadcast_announcement

# When configured, roster generation and parade task assignment
# will automatically send personalised WhatsApp messages to staff.
# Messages will be sent from your registered WhatsApp Business profile
# (which should display "AFCS Smart Campus" or the school name).
# If unset, notifications fall back to SMS, automation webhooks, or the print queue.

# SMS Gateway — Alternative for staff without WhatsApp / no smartphone
# Choose one provider:
# Termii (popular in Nigeria): https://termii.com — get API key from dashboard
TERMII_API_KEY=
TERMII_SENDER_ID=AFCS Campus

# Africa's Talking (pan-Africa): https://africastalking.com
AFRICAS_TALKING_API_KEY=
AFRICAS_TALKING_USERNAME=

# When WhatsApp delivery fails, the system automatically falls back to SMS via
# your configured provider. If no SMS provider is set, notifications are queued
# and visible in the Print Queue at /notifications/print for physical distribution.

# Telegram Bot (free WhatsApp alternative — no Meta account needed)
# Create a bot: https://t.me/botfather — then paste the token here
TELEGRAM_BOT_TOKEN=8832772526:AAHxSERfP4ZXmt5avQCFCD_Kux86gv_GzGI

# Automation Cron Secret (prevents unauthorized automation engine triggers)
# Set a random string here and in Vercel's environment variables.
# The Vercel Cron Job automatically includes this in x-cron-secret header.
CRON_SECRET=change-me-to-a-random-secret-string

# Automation Webhooks (Make.com / n8n)
MAKE_WEBHOOK_URL=
N8N_WEBHOOK_URL=

# AI Assistant (for the in-built AI chat on dashboard)
# Provider: 'openai', 'gemini', or 'ollama' — sets the default; can be toggled in the UI
AI_PROVIDER=openai
# OpenAI
# Get API key: https://platform.openai.com/api-keys
AI_API_KEY=
# Gemini (separate key; also toggled in UI alongside OpenAI)
# Get API key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Ollama (local, free — runs on your own machine)
# Install: https://ollama.com — then `ollama pull qwen3:4b`
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:4b
# Default models (overridable):
AI_MODEL=gpt-4o-mini
GEMINI_MODEL=gemini-2.0-flash
NEXT_PUBLIC_AI_PROVIDER=openai

# === License System ===
# The date until which the app works for free (ISO 8601 format)
# Default: 2027-07-20T00:00:00Z (1 year from initial deployment)
FREE_EXPIRY_DATE=2027-07-20T00:00:00Z
# Master key for reactivation (only the system owner should know this)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_MASTER_KEY=
